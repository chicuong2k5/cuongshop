t; animation-duration: 10s; animation-iteration-count: infinite; }

.shopee-countdown-timer__number__hexa--second { animation-name: second-ten;=
 animation-duration: 60s; animation-iteration-count: infinite; }

.shopee-countdown-timer__number__deca--minute { animation-name: minute-digi=
t; animation-duration: 600s; animation-iteration-count: infinite; }

