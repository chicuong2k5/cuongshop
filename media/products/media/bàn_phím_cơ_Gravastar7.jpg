er; background: currentcolor; border-radius: 2px; justify-content: space-ar=
ound; min-width: 20px; height: 17px; margin-bottom: 4px; padding: 1px 3px; =
font-size: 19px; line-height: 20px; display: flex; overflow: hidden; }

