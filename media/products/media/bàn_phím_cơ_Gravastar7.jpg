pre#chat-text-pre { font-family: var(--font); }

#shopee-mini-chat-embedded { font-family: var(--font); font-weight: 400; li=
ne-height: var(--line-height); }

#shopee-mini-chat-embedded button, #shopee-mini-chat-embedded pre { font-fa=
mily: var(--font); }

#shopee-mini-chat-embedded button:focus { outline: none; }

#shopee-mini-chat-embedded ::-webkit-scrollbar { height: 6px; width: 4px; }

#shopee-mini-chat-embedded ::-webkit-scrollbar-track { background: transpar=
ent; }

#shopee-mini-chat-embedded ::-webkit-scrollbar-thumb { background: rgb(187,=
 187, 187); border-radius: 3px; }

.chat-modal .shopee-react-modal__mask { z-index: 100000; }

.chat-modal .shopee-react-modal__body { align-items: center; display: flex;=
 }

.chat-faq-history-modal .shopee-react-modal__mask { z-index: 100000; }

.chat-easy-window-container { background-color: rgb(255, 255, 255); border:=
 1px solid rgb(220, 220, 224); border-radius: 4px 4px 0px 0px; box-shadow: =
rgba(74, 74, 78, 0.16) 0px 4px 20px 0px; box-sizing: border-box; height: 50=
2px; position: relative; transform: translateX(0px); transition: width 0.25=
s cubic-bezier(0.4, 0.8, 0.74, 1); width: 642px; }

html[lang=3D"my"] { --line-height: 1.5; --font: "SHPBurmese","Droid Sans",A=
rial,sans-serif; }

html[lang=3D"km"] { --line-height: 1.5; --font: "SHPKhmer","Droid Sans",Ari=
al,sans-serif; }

html:not([lang=3D"my"]):not([lang=3D"km"]) { --line-height: 1.2; --font: "R=
oboto","Droid Sans",Arial,sans-serif; }
