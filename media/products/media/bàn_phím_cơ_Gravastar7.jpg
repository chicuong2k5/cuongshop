.shopee-react-zoom-left-leave.shopee-react-zoom-left-leave-active { animati=
on-name: shopeeZoomLeftOut; animation-play-state: running; pointer-events: =
none; }

.shopee-react-zoom-left-appear, .shopee-react-zoom-left-enter { animation-t=
iming-function: cubic-bezier(0.08, 0.82, 0.17, 1); opacity: 0; transform: s=
cale(0); }

.shopee-react-zoom-left-appear-prepare, .shopee-react-zoom-left-enter-prepa=
re { transform: none; }

.shopee-react-zoom-left-leave { animation-timing-function: cubic-bezier(0.7=
8, 0.14, 0.15, 0.86); }

.shopee-react-zoom-right-appear, .shopee-react-zoom-right-enter, .shopee-re=
act-zoom-right-leave { animation-duration: 0.2s; animation-fill-mode: both;=
 animation-play-state: paused; animation-timing-function: ease-in-out; }

.shopee-react-zoom-right-appear.shopee-react-zoom-right-appear-active, .sho=
pee-react-zoom-right-enter.shopee-react-zoom-right-enter-active { animation=
-name: shopeeZoomRightIn; animation-play-state: running; }

.shopee-react-zoom-right-leave.shopee-react-zoom-right-leave-active { anima=
tion-name: shopeeZoomRightOut; animation-play-state: running; pointer-event=
s: none; }

.shopee-react-zoom-right-appear, .shopee-react-zoom-right-enter { animation=
-timing-function: cubic-bezier(0.08, 0.82, 0.17, 1); opacity: 0; transform:=
 scale(0); }

.shopee-react-zoom-right-appear-prepare, .shopee-react-zoom-right-enter-pre=
pare { transform: none; }

.shopee-react-zoom-right-leave { animation-timing-function: cubic-bezier(0.=
78, 0.14, 0.15, 0.86); }

@keyframes shopeeZoomIn {=20
  0% { opacity: 0; transform: scale(0.2); }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes shopeeZoomOut {=20
  0% { transform: scale(1); }
  100% { opacity: 0; transform: scale(0.2); }
}

@keyframes shopeeZoomBigIn {=20
  0% { opacity: 0; transform: scale(0.8); }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes shopeeZoomBigOut {=20
  0% { transform: scale(1); }
  100% { opacity: 0; transform: scale(0.8); }
}

@keyframes shopeeZoomUpIn {=20
  0% { opacity: 0; transform: scale(0.8); transform-origin: 50% 0px; }
  100% { transform: scale(1); transform-origin: 50% 0px; }
}

@keyframes shopeeZoomUpOut {=20
  0% { transform: scale(1); transform-origin: 50% 0px; }
  100% { opacity: 0; transform: scale(0.8); transform-origin: 50% 0px; }
}

@keyframes shopeeZoomLeftIn {=20
  0% { opacity: 0; transform: scale(0.8); transform-origin: 0px 50%; }
  100% { transform: scale(1); transform-origin: 0px 50%; }
}

@keyframes shopeeZoomLeftOut {=20
  0% { transform: scale(1); transform-origin: 0px 50%; }
  100% { opacity: 0; transform: scale(0.8); transform-origin: 0px 50%; }
}

@keyframes shopeeZoomRightIn {=20
  0% { opacity: 0; transform: scale(0.8); transform-origin: 100% 50%; }
  100% { transform: scale(1); transform-origin: 100% 50%; }
}

@keyframes shopeeZoomRightOut {=20
  0% { transform: scale(1); transform-origin: 100% 50%; }
  100% { opacity: 0; transform: scale(0.8); transform-origin: 100% 50%; }
}

@keyframes shopeeZoomDownIn {=20
  0% { opacity: 0; transform: scale(0.8); transform-origin: 50% 100%; }
  100% { transform: scale(1); transform-origin: 50% 100%; }
}

@keyframes shopeeZoomDownOut {=20
  0% { transform: scale(1); transform-origin: 50% 100%; }
  100% { opacity: 0; transform: scale(0.8); transform-origin: 50% 100%; }
}

.shopee-react-modal__mask { background-color: rgba(0, 0, 0, 0.5); inset: 0p=
x; overflow: hidden; position: fixed; z-index: 1000; }

.shopee-react-modal__container { align-items: center; inset: 40px 0px; disp=
lay: flex; justify-content: center; position: absolute; }

.shopee-react-modal__box { display: inline-flex; max-height: 100%; padding:=
 0px 24px; position: relative; transform-origin: center top; }

.shopee-react-modal__content { background-color: rgb(255, 255, 255); border=
-radius: 3px; box-shadow: rgba(0, 0, 0, 0.12) 0px 1px 8px 0px; display: fle=
x; flex-direction: column; max-height: 100%; overflow-y: auto; width: 400px=
; }

.shopee-react-modal__content--medium { width: 500px; }

.shopee-react-modal__content--large { width: 600px; }

.shopee-react-modal__content--x-large { min-height: 400px; width: 800px; }

.shopee-react-modal__content--auto { width: auto; }

.shopee-react-modal__content--center { text-align: center; }

.shopee-react-modal__header { flex-shrink: 0; min-height: 24px; padding: 24=
px; }

.shopee-react-modal__header-inner { position: relative; }

.shopee-react-modal__header-inner__has-back { border-left: 36px solid trans=
parent; }

.shopee-react-modal__header-back.shopee-react-icon { cursor: pointer; line-=
height: 20px; margin-left: -36px; margin-top: 2px; position: absolute; top:=
 0px; width: 20px; }

.shopee-react-modal__title { color: rgb(51, 51, 51); font-size: 20px; font-=
weight: 500; }

.shopee-react-modal__subtitle { color: rgb(153, 153, 153); font-size: 14px;=
 line-height: 1; margin-top: 8px; }

.shopee-react-modal__body { color: rgb(51, 51, 51); flex-grow: 1; font-size=
: 14px; min-height: 32px; overflow: auto; padding: 0px 24px; }

.shopee-react-modal__body.over-height { box-shadow: rgba(0, 0, 0, 0.04) 0px=
 -4px 4px 0px inset; }

.shopee-react-modal__footer { flex-shrink: 0; overflow: hidden; padding: 24=
px; }

.shopee-react-modal__footer.with-assist { display: flex; justify-content: s=
pace-between; }

.shopee-react-modal__footer-buttons { display: inline-flex; float: right; }

.shopee-react-modal__footer-buttons .shopee-react-button:not(:first-of-type=
) { margin-left: 16px; }

.shopee-react-modal__content--center .shopee-react-modal__footer-buttons { =
float: none; }

.shopee-react-modal__close.shopee-react-icon { box-sizing: border-box; colo=
r: rgb(153, 153, 153); cursor: pointer; line-height: 16px; position: absolu=
te; right: 48px; top: 28px; transition: color 0.2s ease-in-out; width: 16px=
; }

.shopee-react-modal__close.shopee-react-icon:focus, .shopee-react-modal__cl=
ose.shopee-react-icon:hover { color: rgb(116, 116, 116); }

.shopee-react-modal-fade-fast-enter { opacity: 0; }

.shopee-react-modal-fade-fast-enter-active { opacity: 1; transition: opacit=
y 0.2s; }

.shopee-react-modal-fade-fast-exit { opacity: 1; }

.shopee-react-modal-fade-fast-exit-active { opacity: 0; transition: opacity=
 0.2s; }

.shopee-react-modal-move-down-fast-enter { opacity: 0; transform: translate=
Y(-10%) scaleY(0.95); }

.shopee-react-modal-move-down-fast-enter-active { opacity: 1; transform: tr=
anslateY(0px) scaleY(1); transition: opacity 0.2s ease-out, transform 0.2s =
ease-out; }

.shopee-react-modal-move-down-fast-exit { opacity: 1; transform: translateY=
(0px) scaleY(1); }

.shopee-react-modal-move-down-fast-exit-active { opacity: 0; transform: tra=
nslateY(-10%) scaleY(0.95); transition: opacity 0.2s ease-out, transform 0.=
2s ease-out; }

