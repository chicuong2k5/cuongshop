, 1) 0s 1 normal none running popover-enter-animation; opacity: 1; z-index:=
 3; }

.stardust-popover__popover--border { border: 1px solid rgba(0, 0, 0, 0.09);=
 }

.stardust-popover__popover--hide { animation: 0.2s cubic-bezier(0.4, 0, 0.6=
, 1) 0s 1 normal none running popover-hide-animation; }

.stardust-popover__arrow { position: absolute; will-change: transform; z-in=
dex: 3; }

